# /etc/wazuh-archiver/archiver.conf
# Wazuh Compliance Log Archiver — configuration template
# Copy to /etc/wazuh-archiver/archiver.conf and edit before use.

[wazuh]
# Comma-separated list of directories to watch for rotated log files.
# When Wazuh runs in Docker with a bind-mount, use the HOST path.
#
# archives  — all events in JSON (logall_json must be enabled in ossec.conf)
# alerts    — alert events only in JSON
# api       — Wazuh API access logs (.log.gz)
# wazuh     — Wazuh manager internal logs (.log.gz)
log_dirs = /var/lib/docker/volumes/single-node_wazuh_logs/_data/archives,
           /var/lib/docker/volumes/single-node_wazuh_logs/_data/alerts,
           /var/lib/docker/volumes/single-node_wazuh_logs/_data/api,
           /var/lib/docker/volumes/single-node_wazuh_logs/_data/wazuh

# File patterns to collect (comma-separated glob patterns, matched recursively).
# *.json.gz — compressed rotated JSON archives (primary Wazuh output)
# *.json    — uncompressed rotated JSON (also produced by Wazuh; requires min_age_minutes)
# *.log.gz  — compressed rotated logs (API, internal Wazuh logs)
file_patterns = *.json.gz, *.json, *.log.gz

# Minimum file age in minutes before an uncompressed file is archived.
# Prevents capturing files Wazuh is still actively writing to.
# Set slightly above rotate_interval (e.g. 65 for rotate_interval=1h).
# Compressed (.gz) files are always safe to archive immediately.
min_age_minutes = 65

# Identifies this Wazuh node in audit records and remote filenames
node_name = wazuh-node1


[sftp]
# Hostname or IP of the SFTP server
host = sftp.example.com

# SSH port (default 22)
port = 22

# SFTP username
username = wazuh-archiver

# Path to the SSH private key used for authentication (chmod 400, owned by service user)
# Generate with: ssh-keygen -t ed25519 -f /etc/wazuh-archiver/sftp_key -N ""
ssh_key_path = /etc/wazuh-archiver/sftp_key

# Remote destination directory (will be created if it does not exist)
remote_dir = /archive/wazuh

# SSH known_hosts file for strict host-key verification (STRONGLY RECOMMENDED).
# Generate with:
#   ssh-keyscan -H sftp.example.com >> /etc/wazuh-archiver/known_hosts
# Leave empty to use WarningPolicy (not recommended for production).
known_hosts_file = /etc/wazuh-archiver/known_hosts


[gpg]
# --- Signing ---
# Each archive gets a detached armored signature (.sig).
# Proves origin (Wazuh node) and integrity (data unchanged after transfer).
# Generate the signing key: sudo bash create-signing-key.sh
signing = true

# Key ID or fingerprint of the signing key on this machine.
signing_key_id =

# --- Encryption ---
# An encrypted copy of the archive is uploaded (.gpg).
# The PUBLIC key encrypts (stays on this machine).
# The PRIVATE key decrypts (store in secure offline location).
# Generate the encryption key pair: sudo bash create-encryption-key.sh
encryption = true

# Fingerprint of the encryption key generated by create-encryption-key.sh.
encryption_recipient =

# Whether to upload the plaintext archive alongside the encrypted copy.
# Set to false to upload only the .gpg file (requires encryption = true).
# The .sha256 manifest is always uploaded regardless of this setting —
# it digests the original plaintext so integrity can be verified after decryption.
upload_plaintext = true

# Path to the gpg binary
gpg_binary = /usr/bin/gpg

# GPG home directory for the signing key (must be owned by the service user, chmod 700)
signing_homedir = /etc/wazuh-archiver/signing/gnupg

# GPG home directory for the encryption key (must be owned by the service user, chmod 700)
encryption_homedir = /etc/wazuh-archiver/encryption/gnupg


[transfer]
# Which transport(s) to use for uploading files.
# Options: sftp, webdav, ftp, ftps — or a comma-separated combination.
# Default: sftp (backwards compatible — no change required for existing deployments)
#
# Examples:
#   mode = sftp           — SSH key-based transfer (default)
#   mode = ftps           — FTPS explicit (AUTH TLS), username + password
#   mode = sftp,ftps      — upload to both simultaneously (redundancy)
mode = sftp


[webdav]
# WebDAV HTTPS destination (required only when transfer.mode includes "webdav").
#
# Synology DSM WebDAV port:  5001 (HTTPS)
# QNAP QTS WebDAV port:      5006 (HTTPS)
#
# Include the full URL with protocol and port:
url = https://nas.example.com:5001

# Remote destination directory (will be created via MKCOL if it does not exist)
remote_dir = /archive/wazuh

# HTTP Basic Auth username
username = wazuh-archiver

# Path to a file containing ONLY the password (no trailing newline required).
# Create with:  printf '%s' 'your-password' > /etc/wazuh-archiver/webdav_password
# Permissions:  chmod 440 /etc/wazuh-archiver/webdav_password
#               chown root:wazuh-archiver /etc/wazuh-archiver/webdav_password
password_file = /etc/wazuh-archiver/webdav_password

# TLS certificate verification:
#   true            — verify against the system's trusted CA store (for public certs)
#   /path/to/ca.pem — path to a PEM CA bundle for self-signed or private CA certs
#   false           — disable verification entirely (NOT recommended in production)
#
# Synology/QNAP self-signed certificates:
#   DSM: Control Panel → Security → Certificate → Export certificate → download root.pem
#   Then: cp root.pem /etc/wazuh-archiver/webdav_ca.pem
#         chown root:wazuh-archiver /etc/wazuh-archiver/webdav_ca.pem
#         chmod 640 /etc/wazuh-archiver/webdav_ca.pem
ca_cert = /etc/wazuh-archiver/webdav_ca.pem


[ftp]
# Plain FTP — username + password, no encryption.
# NOTE: Credentials and file data are transmitted in cleartext.
# Use only on closed internal networks or when FTPS is unavailable.

# Hostname or IP of the FTP server
host = ftp.example.com

# FTP port (default 21)
port = 21

# FTP username
username = wazuh-archiver

# Path to a file containing ONLY the password (no trailing newline required).
# Create:      printf '%s' 'your-password' > /etc/wazuh-archiver/ftp_password
# Permissions: chmod 440 /etc/wazuh-archiver/ftp_password
#              chown root:wazuh-archiver /etc/wazuh-archiver/ftp_password
password_file = /etc/wazuh-archiver/ftp_password

# Remote destination directory (will be created via MKD if it does not exist)
remote_dir = /archive/wazuh

# Passive mode (PASV) — strongly recommended, required by most firewalls
passive_mode = true


[ftps]
# FTPS explicit (AUTH TLS) — username + password, TLS-encrypted.
# Connection flow: plain TCP connect → login → AUTH TLS on control channel
#                 → PROT P upgrades data channel to TLS → file transfer
# Both credentials and file data are protected by TLS.

# Hostname or IP of the FTPS server
host = ftps.example.com

# FTPS port — explicit mode uses 21 (same as FTP)
port = 21

# FTPS username
username = wazuh-archiver

# Path to a file containing ONLY the password (no trailing newline required).
# Create:      printf '%s' 'your-password' > /etc/wazuh-archiver/ftps_password
# Permissions: chmod 440 /etc/wazuh-archiver/ftps_password
#              chown root:wazuh-archiver /etc/wazuh-archiver/ftps_password
password_file = /etc/wazuh-archiver/ftps_password

# Remote destination directory (will be created via MKD if it does not exist)
remote_dir = /archive/wazuh

# TLS certificate verification (same syntax as [webdav] ca_cert):
#   true            — verify against the system's trusted CA store
#   /path/to/ca.pem — custom CA bundle for self-signed server certificates
#   false           — disable verification (NOT recommended in production)
ca_cert = true

# Passive mode (PASV) — strongly recommended, required by most firewalls
passive_mode = true


[archiver]
# JSON file that tracks which log files have already been processed.
# Prevents re-uploading after restarts.
state_file = /var/lib/wazuh-archiver/state.json

# Rotating audit log (50 MB per file, 12 backups = ~600 MB max)
# Contains one JSON AUDIT_RECORD line per processed file.
audit_log = /var/log/wazuh-archiver/audit.log

# Temporary working directory.  Cleaned up after every run.
# Should be on the same filesystem as the log_dirs for efficient copies.
temp_dir = /tmp/wazuh-archiver
